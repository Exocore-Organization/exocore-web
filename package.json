{
  "name": "exocore-web",
  "version": "4.0.0",
  "description": "Exocore 2026 — Autonomous multi-project runtime manager and dev panel.",
  "main": "exocore-web/index.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx exocore-web/index.ts",
    "start": "tsx exocore-web/index.ts",
    "build:client": "node_modules/.bin/vite build --config exocore-web/vite.config.mts",
    "build:server": "tsc -p exocore-web/tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "typecheck": "tsc -p exocore-web/tsconfig.json --noEmit"
  },
