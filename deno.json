{
  "nodeModulesDir": "auto",
  "unstable": ["sloppy-imports", "node-globals"],
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "ESNext"]
  },
  "imports": {
    "http": "node:http",
    "https": "node:https",
    "net": "node:net",
    "fs": "node:fs",
    "fs/promises": "node:fs/promises",
    "path": "node:path",
    "crypto": "node:crypto",
    "os": "node:os",
    "child_process": "node:child_process",
    "url": "node:url",
    "util": "node:util",
    "stream": "node:stream",
    "buffer": "node:buffer",
    "events": "node:events",
    "assert": "node:assert",
    "querystring": "node:querystring",
    "string_decoder": "node:string_decoder",
    "timers": "node:timers",
    "tty": "node:tty",
    "zlib": "node:zlib",
    "cluster": "node:cluster",
    "dns": "node:dns",
    "dgram": "node:dgram",
    "readline": "node:readline",
    "repl": "node:repl",
    "v8": "node:v8",
    "vm": "node:vm",
    "worker_threads": "node:worker_threads",
    "perf_hooks": "node:perf_hooks",
    "async_hooks": "node:async_hooks",
    "module": "node:module",
    "punycode": "node:punycode",
    "express": "npm:express@5",
    "express/": "npm:express@5/",
    "ws": "npm:ws@8",
    "multer": "npm:multer@2",
    "archiver": "npm:archiver@7",
    "adm-zip": "npm:adm-zip@0.5",
    "compression": "npm:compression@1",
    "helmet": "npm:helmet@8",
    "morgan": "npm:morgan@1",
    "cors": "npm:cors@2",
    "cloudflared": "npm:cloudflared@0",
    "axios": "npm:axios@1",
    "cheerio": "npm:cheerio@1",
    "form-data": "npm:form-data@4",
    "zod": "npm:zod@4",
    "p-limit": "npm:p-limit@7",
    "p-retry": "npm:p-retry@7",
    "@msgpack/msgpack": "npm:@msgpack/msgpack@3",
    "cookie-parser": "npm:cookie-parser@1",
    "body-parser": "npm:body-parser@1",
    "highlight.js": "npm:highlight.js@11",
    "typescript": "npm:typescript@5"
  },
  "tasks": {
    "compile": "deno compile --allow-net --allow-read --allow-write --allow-run --allow-env --allow-sys --unstable-sloppy-imports --unstable-node-globals --output exocore-web backup/exocore-ide/packages/index.ts",
    "compile-linux": "deno compile --target x86_64-unknown-linux-gnu --allow-net --allow-read --allow-write --allow-run --allow-env --allow-sys --unstable-sloppy-imports --unstable-node-globals --output exocore-web backup/exocore-ide/packages/index.ts",
    "compile-win": "deno compile --target x86_64-pc-windows-msvc --allow-net --allow-read --allow-write --allow-run --allow-env --allow-sys --unstable-sloppy-imports --unstable-node-globals --output exocore-web.exe backup/exocore-ide/packages/index.ts",
    "compile-mac": "deno compile --target x86_64-apple-darwin --allow-net --allow-read --allow-write --allow-run --allow-env --allow-sys --unstable-sloppy-imports --unstable-node-globals --output exocore-web-mac backup/exocore-ide/packages/index.ts",
    "compile-mac-arm": "deno compile --target aarch64-apple-darwin --allow-net --allow-read --allow-write --allow-run --allow-env --allow-sys --unstable-sloppy-imports --unstable-node-globals --output exocore-web-mac-arm backup/exocore-ide/packages/index.ts"
  }
}
